<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="fbdump" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Windows">
				<Option output="build/fbdump" prefix_auto="1" extension_auto="1" />
				<Option working_dir="build" />
				<Option object_output="build/obj/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O3" />
					<Add option="-municode" />
					<Add option="-D_UNICODE" />
				</Compiler>
				<Linker>
					<Add option="-municode" />
					<Add option="-static-libgcc" />
					<Add option="-static-libstdc++" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Werror" />
			<Add option="-Wshadow" />
			<Add option="-Wextra" />
			<Add option="-Wall" />
			<Add option="-ggdb" />
			<Add option="-fexceptions" />
			<Add option="--std=c++17" />
		</Compiler>
		<Unit filename="detector.cpp" />
		<Unit filename="detector.h" />
		<Unit filename="dumper.cpp" />
		<Unit filename="dumper.h" />
		<Unit filename="fbinterface.h" />
		<Unit filename="journal.cpp" />
		<Unit filename="journal.h" />
		<Unit filename="main.cpp" />
		<Unit filename="reader.cpp" />
		<Unit filename="reader.h" />
		<Unit filename="static_exception.h" />
		<Unit filename="status.cpp" />
		<Unit filename="status.h" />
		<Unit filename="tstring.cpp" />
		<Unit filename="tstring.h" />
		<Extensions />
	</Project>
</CodeBlocks_project_file>
